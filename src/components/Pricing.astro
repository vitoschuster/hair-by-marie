---

<section id="cjenik" class="py-24 bg-cream">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="h-px w-12" style="background-color: var(--color-gold)"></div>
        <span class="font-sans text-xs font-medium tracking-[0.3em] uppercase" style="color: var(--color-gold)">
          Transparentne cijene
        </span>
        <div class="h-px w-12" style="background-color: var(--color-gold)"></div>
      </div>
      <h2 class="font-serif text-4xl lg:text-5xl font-semibold section-title" style="color: var(--color-dark)">
        Cjenik usluga
      </h2>
      <p class="font-sans text-base max-w-lg mx-auto mt-6 leading-relaxed" style="color: var(--color-brown-light)">
        Sve cijene uključuju PDV. Za točnu cijenu ovisno o dužini i gustoći vaše kose, preporučujemo konzultaciju.
      </p>
    </div>

    <!-- Accordions -->
    <div class="flex flex-col gap-3">
      {categories.map((cat, i) => (
        <div class="rounded-2xl overflow-hidden border" style="border-color: var(--color-linen)">
          <button
            class="accordion-btn w-full flex items-center justify-between px-6 py-5 text-left transition-colors duration-200 hover:cursor-pointer"
            style="background-color: var(--color-beige)"
            aria-expanded={i === 0 ? 'true' : 'false'}
            data-accordion={cat.id}
          >
            <span class="font-serif text-lg font-semibold" style="color: var(--color-dark)">{cat.label}</span>
            <div class="flex items-center gap-3">
              <span class="font-sans text-xs" style="color: var(--color-brown-light)">{cat.services.length} usluga</span>
              <svg class="accordion-icon w-5 h-5 flex-shrink-0" style="color: var(--color-gold)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 5v14M5 12h14"/>
              </svg>
            </div>
          </button>

          <div
            class={`accordion-content${i === 0 ? ' open' : ''}`}
            id={`accordion-${cat.id}`}
          >
            <div style="background-color: var(--color-cream)">
              <table class="w-full">
                <thead>
                  <tr style="background-color: var(--color-beige)">
                    <th class="font-sans text-xs font-medium uppercase tracking-wider text-left px-6 py-3" style="color: var(--color-brown-light)">Usluga</th>
                    <th class="font-sans text-xs font-medium uppercase tracking-wider text-center px-4 py-3 hidden sm:table-cell" style="color: var(--color-brown-light)">Trajanje</th>
                    <th class="font-sans text-xs font-medium uppercase tracking-wider text-right px-6 py-3" style="color: var(--color-brown-light)">Cijena</th>
                  </tr>
                </thead>
                <tbody>
                  {cat.services.map((svc, j) => (
                    <tr class="price-row border-t" style={`border-color: var(--color-linen); background-color: ${j % 2 === 1 ? 'var(--color-beige)' : 'transparent'}`}>
                      <td class="font-sans text-sm px-6 py-3.5" style="color: var(--color-text)">{svc.name}</td>
                      <td class="font-sans text-xs text-center px-4 py-3.5 hidden sm:table-cell" style="color: var(--color-brown-light)">{svc.duration}</td>
                      <td class="font-serif text-sm font-semibold text-right px-6 py-3.5" style="color: var(--color-brown)">{svc.price}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Note -->
    <div class="mt-8 rounded-2xl p-6 flex gap-4" style="background-color: var(--color-beige)">
      <svg class="flex-shrink-0 mt-0.5" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--color-gold)">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p class="font-sans text-sm leading-relaxed" style="color: var(--color-brown-light)">
        Svaka stavka naplaćuje se zasebno. Cijene mogu varirati ovisno o dužini, gustoći i stanju kose.
        Za rezervaciju termina posjetite <a href="https://www.sredime.hr/zagreb/salon-hair-by-marie" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--color-gold)">sredime.hr</a> ili nas nazovite na <a href="tel:+385919307334" class="underline" style="color: var(--color-gold)">+385 91 930 7334</a>.
      </p>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.accordion-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.accordion!;
      const content = document.getElementById(`accordion-${id}`)!;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all
      document.querySelectorAll<HTMLButtonElement>('.accordion-btn').forEach((b) => {
        b.setAttribute('aria-expanded', 'false');
        const c = document.getElementById(`accordion-${b.dataset.accordion!}`);
        c?.classList.remove('open');
      });

      // Open clicked if was closed
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        content.classList.add('open');
      }
    });
  });
</script>
