---
const year = new Date().getFullYear();

const links = [
  { href: '#usluge', label: 'Usluge' },
  { href: '#galerija', label: 'Galerija' },
  { href: '#cjenik', label: 'Cjenik' },
  { href: '#o-nama', label: 'O nama' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<footer style="background-color: var(--color-dark)">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Top section -->
    <div class="py-16 grid sm:grid-cols-2 lg:grid-cols-4 gap-10 border-b" style="border-color: rgba(255,255,255,0.08)">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="mb-4">
          <span class="font-serif text-3xl font-semibold text-cream" style="color: var(--color-cream)">
            Hair by Marie
          </span>
          <p class="font-sans text-xs tracking-[0.3em] uppercase mt-1" style="color: var(--color-gold)">
            Beauty &amp; Health
          </p>
        </div>
        <p class="font-sans text-sm leading-relaxed max-w-xs" style="color: rgba(255,255,255,0.55)">
          Profesionalni frizerski salon u Zagrebu. Koristimo Kevin Murphy proizvode za najkvalitetniji rezultat.
        </p>

        <!-- Social -->
        <div class="flex gap-4 mt-6">
          <a
            href="https://www.instagram.com/hair__by__marie__/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 rounded-full flex items-center justify-center transition-colors duration-200"
            style="background-color: rgba(255,255,255,0.08)"
            onmouseover="this.style.backgroundColor='var(--color-gold)'"
            onmouseout="this.style.backgroundColor='rgba(255,255,255,0.08)'"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="color: var(--color-cream)">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-sans text-xs font-semibold tracking-[0.25em] uppercase mb-5" style="color: var(--color-gold)">
          Navigacija
        </h4>
        <ul class="flex flex-col gap-3">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-sans text-sm transition-colors duration-200"
                style="color: rgba(255,255,255,0.55)"
                onmouseover="this.style.color='var(--color-cream)'"
                onmouseout="this.style.color='rgba(255,255,255,0.55)'"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h4 class="font-sans text-xs font-semibold tracking-[0.25em] uppercase mb-5" style="color: var(--color-gold)">
          Informacije
        </h4>
        <div class="flex flex-col gap-3">
          <div>
            <p class="font-sans text-xs uppercase tracking-wider mb-1" style="color: rgba(255,255,255,0.35)">Adresa</p>
            <p class="font-sans text-sm" style="color: rgba(255,255,255,0.7)">Vukomerec 36, Zagreb</p>
          </div>
          <div>
            <p class="font-sans text-xs uppercase tracking-wider mb-1" style="color: rgba(255,255,255,0.35)">Radno vrijeme</p>
            <p class="font-sans text-sm" style="color: rgba(255,255,255,0.7)">Pon–Pet: 08:00–20:00</p>
            <p class="font-sans text-sm" style="color: rgba(255,255,255,0.7)">Sub: 08:00–14:00</p>
          </div>
          <div>
            <p class="font-sans text-xs uppercase tracking-wider mb-1" style="color: rgba(255,255,255,0.35)">Telefon</p>
            <a href="tel:+385919307334" class="font-sans text-sm" style="color: rgba(255,255,255,0.7)">+385 91 930 7334</a>
          </div>
          <div>
            <p class="font-sans text-xs uppercase tracking-wider mb-1" style="color: rgba(255,255,255,0.35)">Plaćanje</p>
            <p class="font-sans text-sm" style="color: rgba(255,255,255,0.7)">Gotovina i kartice</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-sans text-xs" style="color: rgba(255,255,255,0.35)">
        &copy; {year} Hair by Marie. Sva prava pridržana.
      </p>
      <p class="font-sans text-xs" style="color: rgba(255,255,255,0.25)">
        HAIR BY MARIE j.d.o.o. · OIB: 54824337170
      </p>
    </div>
  </div>
</footer>
