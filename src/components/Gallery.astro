---
const beholdFeedId = import.meta.env.PUBLIC_BEHOLD_FEED_ID;
---

<section id="galerija" class="py-24" style="background-color: var(--color-beige)">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="h-px w-12" style="background-color: var(--color-gold)"></div>
          <span class="font-sans text-xs font-medium tracking-[0.3em] uppercase" style="color: var(--color-gold)">
            Instagram
          </span>
        </div>
        <h2 class="font-serif text-4xl lg:text-5xl font-semibold section-title left" style="color: var(--color-dark)">
          Naša galerija
        </h2>
      </div>
      <a
        href="https://www.instagram.com/hair__by__marie__/"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 lg:mt-0 inline-flex items-center gap-2 font-sans text-sm font-medium transition-colors duration-200"
        style="color: var(--color-brown)"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        @hair__by__marie__
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </div>

    <!-- Instagram Feed -->
    {beholdFeedId ? (
      <!-- Behold.so widget - configure at https://behold.so -->
      <div class="rounded-3xl overflow-hidden">
        <behold-widget feed-id={beholdFeedId}></behold-widget>
        <script src="https://w.behold.so/widget.js" type="module" is:inline></script>
      </div>
    ) : (
      <!-- Placeholder grid when no feed ID is set -->
      <div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 lg:gap-4">
          {[
            'https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=600&q=80',
            'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=600&q=80',
            'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=600&q=80',
            'https://images.unsplash.com/photo-1562322140-8baeececf3df?w=600&q=80',
            'https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=600&q=80',
            'https://images.unsplash.com/photo-1523263685509-57c1d050d19b?w=600&q=80',
            'https://images.unsplash.com/photo-1492106087820-71f1a00d2b11?w=600&q=80',
            'https://images.unsplash.com/photo-1503951914875-452162b0f3f1?w=600&q=80',
          ].map((src, i) => (
            <a
              href="https://www.instagram.com/hair__by__marie__/"
              target="_blank"
              rel="noopener noreferrer"
              class="group relative aspect-square overflow-hidden rounded-2xl"
            >
              <img
                src={src}
                alt={`Hair by Marie galerija ${i + 1}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
              <!-- Hover overlay -->
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
                style="background-color: rgba(107, 66, 38, 0.5)">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </div>
            </a>
          ))}
        </div>

        <!-- Setup note (shown in dev, hidden in prod via CSS) -->
        <p class="text-center mt-6 font-sans text-xs" style="color: var(--color-brown-light)">
          Za pravi Instagram feed, postavi <code class="bg-linen px-1 rounded" style="background-color: var(--color-linen)">PUBLIC_BEHOLD_FEED_ID</code> varijablu →
          <a href="https://behold.so" target="_blank" rel="noopener noreferrer" class="underline" style="color: var(--color-gold)">behold.so</a>
        </p>
      </div>
    )}
  </div>
</section>
