---
const services = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9H4.5a2.5 2.5 0 010-5H6"/><path d="M18 9h1.5a2.5 2.5 0 000-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0012 0V2z"/></svg>`,
    title: 'Šišanje',
    subtitle: 'Muško, žensko, dječje',
    description: 'Moderni rezovi prilagođeni vašem licu i stilu. Od klasičnih do najsuvremenijih trendova.',
    price: 'od 15€',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 20v-8.5"/><path d="M20 20H4"/></svg>`,
    title: 'Bojanje',
    subtitle: 'Balayage & highlights',
    description: 'Punobojno bojanje, pramenovi, balayage i color melt tehnike za savršen rezultat.',
    price: 'od 30€',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22a7 7 0 007-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 007 7z"/></svg>`,
    title: 'Feniranje',
    subtitle: 'Ravno, valovi & četke',
    description: 'Profesionalno feniranje na ravno, valove ili okrugle četke za voluminoznu frizuru.',
    price: 'od 15€',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'Ekstenzije',
    subtitle: 'Keratin nanosi',
    description: 'Keratin ekstenzije za dužinu i volumen. Dostupne u dužinama od 30 do 60 cm.',
    price: 'od 4€/kom',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    title: 'Svečane frizure',
    subtitle: 'Punđe & Hollywood valovi',
    description: 'Elegatne punđe, Hollywood valovi, pletenice i ponytail frizure za svečane prigode.',
    price: 'od 25€',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Njega kose',
    subtitle: 'Tretmani & maske',
    description: 'Ampule, maske, dubinska njega i piling tjemena za zdravu i sjajnu kosu.',
    price: 'od 5€',
  },
];
---

<section id="usluge" class="py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="h-px w-12 bg-gold" style="background-color: var(--color-gold)"></div>
        <span class="font-sans text-xs font-medium tracking-[0.3em] uppercase text-gold" style="color: var(--color-gold)">
          Što nudimo
        </span>
        <div class="h-px w-12 bg-gold" style="background-color: var(--color-gold)"></div>
      </div>
      <h2 class="font-serif text-4xl lg:text-5xl font-semibold text-dark section-title" style="color: var(--color-dark)">
        Naše usluge
      </h2>
      <p class="font-sans text-base max-w-xl mx-auto mt-6 leading-relaxed" style="color: var(--color-brown-light)">
        Pružamo sveobuhvatne usluge njege i stiliziranja kose koristeći premium Kevin Murphy proizvode.
      </p>
    </div>

    <!-- Service grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="group bg-beige rounded-3xl p-8 hover:bg-linen transition-all duration-300 hover:-translate-y-1 hover:shadow-lg cursor-default"
          style="background-color: var(--color-beige)">
          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6 transition-colors duration-300"
            style="background-color: var(--color-linen); color: var(--color-brown)">
            <Fragment set:html={service.icon} />
          </div>

          <!-- Content -->
          <h3 class="font-serif text-xl font-semibold mb-1" style="color: var(--color-dark)">
            {service.title}
          </h3>
          <p class="font-sans text-xs font-medium tracking-wider uppercase mb-3" style="color: var(--color-gold)">
            {service.subtitle}
          </p>
          <p class="font-sans text-sm leading-relaxed mb-5" style="color: var(--color-brown-light)">
            {service.description}
          </p>

          <!-- Price + link -->
          <div class="flex items-center justify-between">
            <span class="font-serif text-lg font-semibold" style="color: var(--color-brown)">
              {service.price}
            </span>
            <a href="#cjenik" class="font-sans text-xs font-medium underline underline-offset-2 opacity-0 group-hover:opacity-100 transition-opacity"
              style="color: var(--color-gold)">
              Vidi cjenik →
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-14">
      <a
        href="https://www.sredime.hr/zagreb/salon-hair-by-marie"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-sans text-sm font-medium px-8 py-4 rounded-full transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg"
        style="background-color: var(--color-brown); color: var(--color-cream)"
      >
        Rezerviraj termin online
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
